digraph SystemOverview {
  graph [
    rankdir=TB,
    bgcolor="#ffffff",
    pad="0.55",
    nodesep="0.55",
    ranksep="0.85",
    splines=polyline,
    outputorder=edgesfirst,
    compound=true,
    newrank=true,
    forcelabels=true,
    fontname="Avenir",
    label=<
      <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="0">
        <TR><TD><FONT POINT-SIZE="34"><B>Geno-2 — System Overview</B></FONT></TD></TR>
      </TABLE>
    >,
    labelloc=t,
    labeljust=c
  ];

  node [
    shape=box,
    style="rounded,filled",
    margin="0.21,0.13",
    width=3.05,
    height=0.74,
    fixedsize=false,
    fontname="Avenir",
    fontsize=18,
    penwidth=2.4,
    fontcolor="#14213d",
    color="#2264c7",
    fillcolor="#eaf3ff:#ffffff",
    gradientangle=270
  ];

  edge [
    color="#263a59",
    fontname="Avenir",
    fontsize=13,
    fontcolor="#3d4a5c",
    penwidth=2.2,
    arrowsize=0.78
  ];

  // ---- Host ----
  subgraph cluster_host {
    graph [
      label=<
        <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="2">
          <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="17" COLOR="#0f766e"><B>HOST</B></FONT></TD></TR>
          <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="12" COLOR="#357a74">Cloudflare Worker serves the built dist/ directory.</FONT></TD></TR>
        </TABLE>
      >,
      labelloc=t, labeljust=l,
      color="#99d5cf", fillcolor="#f0fdfa", style="rounded,filled", penwidth=1.8, margin=22
    ];
    H1 [label=<<B>Cloudflare Worker</B><BR/><FONT POINT-SIZE="15">worker.js · dist/: app_web.js + _bg.wasm + index.html</FONT>>, fillcolor="#e6fffb:#ffffff", color="#0f766e"];
  }

  // ---- Browser ----
  subgraph cluster_browser {
    graph [
      label=<
        <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="2">
          <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="17" COLOR="#1f5fbf"><B>BROWSER</B></FONT></TD></TR>
          <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="12" COLOR="#496f9f">A WebGPU + WebAudio page driving a requestAnimationFrame loop.</FONT></TD></TR>
        </TABLE>
      >,
      labelloc=t, labeljust=l,
      color="#b9d8ff", fillcolor="#f5faff", style="rounded,filled", penwidth=1.8, margin=22
    ];
    B1 [label=<<B>index.html bootstrap</B><BR/><FONT POINT-SIZE="15">checks navigator.gpu + AudioContext, imports app_web.js</FONT>>, fillcolor="#edf7ff:#ffffff", color="#2f80ed"];
    B2 [label=<<B>requestAnimationFrame loop</B><BR/><FONT POINT-SIZE="15">FrameContext::frame, every frame</FONT>>, fillcolor="#edf7ff:#ffffff", color="#2f80ed"];
    B3 [label=<<B>Input</B><BR/><FONT POINT-SIZE="15">pointer · keyboard · multitouch</FONT>>, fillcolor="#edf7ff:#ffffff", color="#2f80ed"];
    B1 -> B2 [style=invis];
    B2 -> B3 [style=invis];
  }

  // ---- WASM app core ----
  subgraph cluster_core {
    graph [
      label=<
        <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="2">
          <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="17" COLOR="#1e6b43"><B>WASM APP CORE (RUST)</B></FONT></TD></TR>
          <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="12" COLOR="#4e7a61">wasm_app wires the engine, audio, input, and renderer; FrameContext runs each frame.</FONT></TD></TR>
        </TABLE>
      >,
      labelloc=t, labeljust=l,
      color="#b8e5c8", fillcolor="#f4fbf6", style="rounded,filled", penwidth=1.8, margin=22
    ];
    C1 [label=<<B>wasm_app</B><BR/><FONT POINT-SIZE="15">#[wasm_bindgen(start)] · composition root</FONT>>, fillcolor="#eaf8ef:#ffffff", color="#22865a"];
    C2 [label=<<B>MusicEngine</B><BR/><FONT POINT-SIZE="15">eighth-note scheduler → NoteEvents</FONT>>, fillcolor="#eaf8ef:#ffffff", color="#22865a"];
    C3 [label=<<B>FrameContext</B><BR/><FONT POINT-SIZE="15">schedule · couple state · render</FONT>>, fillcolor="#eaf8ef:#ffffff", color="#22865a"];
    C1 -> C2 [style=invis];
  }

  // ---- WebAudio ----
  subgraph cluster_audio {
    graph [
      label=<
        <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="2">
          <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="17" COLOR="#a5610a"><B>WEBAUDIO</B></FONT></TD></TR>
          <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="12" COLOR="#9a6a1f">Procedural synthesis + FX graph (see audio-graph).</FONT></TD></TR>
        </TABLE>
      >,
      labelloc=t, labeljust=l,
      color="#f0d79a", fillcolor="#fffbf0", style="rounded,filled", penwidth=1.8, margin=22
    ];
    A1 [label=<<B>Audio graph</B><BR/><FONT POINT-SIZE="15">voices → reverb/delay → master tone/sat/comp</FONT>>, fillcolor="#fff4d1:#fffaf0", color="#d39a00"];
  }

  // ---- GPU ----
  subgraph cluster_gpu {
    graph [
      label=<
        <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="2">
          <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="17" COLOR="#5f3b8a"><B>GPU (WEBGPU)</B></FONT></TD></TR>
          <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="12" COLOR="#6d4d8d">Screen-space shader; no 3D scene, no depth buffer.</FONT></TD></TR>
        </TABLE>
      >,
      labelloc=t, labeljust=l,
      color="#d6c6ee", fillcolor="#fbf8ff", style="rounded,filled", penwidth=1.8, margin=22
    ];
    G1 [label=<<B>Waves pass</B><BR/><FONT POINT-SIZE="15">waves.wgsl · swirl · voice influence · ripples → HDR</FONT>>, fillcolor="#f5f3ff:#ffffff", color="#7c3aed"];
    G2 [label=<<B>Bloom + composite</B><BR/><FONT POINT-SIZE="15">post.wgsl · bright-pass · blur · ACES · grain</FONT>>, fillcolor="#f5f3ff:#ffffff", color="#7c3aed"];
  }

  // ---- Outputs ----
  SPK [label=<<B>speakers</B><BR/><FONT POINT-SIZE="15">AudioContext.destination</FONT>>, fillcolor="#d8f5de:#effcf2", color="#15803d", penwidth=3.0];
  CANVAS [label=<<B>&lt;canvas&gt;</B><BR/><FONT POINT-SIZE="15">on-screen frame</FONT>>, fillcolor="#d8f5de:#effcf2", color="#15803d", penwidth=3.0];

  // ---- Edges ----
  H1 -> B1 [lhead=cluster_browser, label="serves page + WASM"];

  B1 -> C1 [lhead=cluster_core, label="init"];
  B2 -> C3 [label="frame()"];
  B3 -> C3 [label="pointer · keys", color="#6b7280", fontcolor="#6b7280", style=dashed];

  C1 -> C3 [label="owns / drives"];
  C2 -> C3 [label="NoteEvents"];

  C3 -> A1 [lhead=cluster_audio, label="schedule + trigger notes"];
  C3 -> G1 [lhead=cluster_gpu, label="uniforms per frame"];

  A1 -> SPK [ltail=cluster_audio, label="render to destination"];
  G1 -> G2 [label="HDR scene"];
  G2 -> CANVAS [ltail=cluster_gpu, label="composite to swapchain"];
}
