digraph AudioGraph {
  graph [
    rankdir=TB,
    bgcolor="#ffffff",
    pad="0.55",
    nodesep="0.45",
    ranksep="0.70",
    splines=spline,
    outputorder=edgesfirst,
    compound=true,
    newrank=true,
    forcelabels=true,
    fontname="Avenir",
    label=<
      <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="0">
        <TR><TD><FONT POINT-SIZE="34"><B>Audio Graph — WebAudio Topology</B></FONT></TD></TR>
        <TR><TD><FONT POINT-SIZE="14" COLOR="#5b6b80">Built once at startup; the frame loop only writes AudioParam values.</FONT></TD></TR>
      </TABLE>
    >,
    labelloc=t,
    labeljust=c
  ];

  node [
    shape=box,
    style="rounded,filled",
    margin="0.20,0.13",
    width=2.55,
    height=0.70,
    fixedsize=false,
    fontname="Avenir",
    fontsize=18,
    penwidth=2.4,
    fontcolor="#14213d",
    color="#d39a00",
    fillcolor="#fff4d1:#fffaf0",
    gradientangle=270
  ];

  edge [
    color="#263a59",
    fontname="Avenir",
    fontsize=13,
    fontcolor="#3d4a5c",
    penwidth=2.2,
    arrowsize=0.78
  ];

  // ---- Generation (Rust core) ----
  ENG  [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="0"><TR><TD><B>MusicEngine</B></TD></TR><TR><TD CELLPADDING="4"><FONT POINT-SIZE="15">eighth-note scheduler</FONT></TD></TR></TABLE>>, fillcolor="#eaf8ef:#ffffff", color="#22865a"];
  NOTE [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="0"><TR><TD><B>NoteEvent</B></TD></TR><TR><TD CELLPADDING="4"><FONT POINT-SIZE="15">voice · frequency · velocity · dur</FONT></TD></TR></TABLE>>, fillcolor="#eaf8ef:#ffffff", color="#22865a"];

  // ---- Per-note synthesis ----
  subgraph cluster_note {
    graph [
      label=<
        <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="2">
          <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="16" COLOR="#a5610a"><B>PER NOTE</B></FONT></TD></TR>
          <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="12" COLOR="#9a6a1f">A fresh oscillator pair + envelope per NoteEvent.</FONT></TD></TR>
        </TABLE>
      >,
      labelloc=t, labeljust=l,
      color="#f0d79a", fillcolor="#fffbf0", style="rounded,filled", penwidth=1.8, margin=18
    ];
    OSC [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="0"><TR><TD><B>OscillatorNode ×2</B></TD></TR><TR><TD CELLPADDING="4"><FONT POINT-SIZE="15">waveform + detuned chorus</FONT></TD></TR></TABLE>>];
    ENV [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="0"><TR><TD><B>env GainNode</B></TD></TR><TR><TD CELLPADDING="4"><FONT POINT-SIZE="15">attack · sustain · release</FONT></TD></TR></TABLE>>];
    OSC -> ENV;
  }

  // ---- Three parallel paths from the envelope ----
  subgraph cluster_voice {
    graph [
      label=<
        <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="2">
          <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="16" COLOR="#a5610a"><B>PER VOICE</B></FONT></TD></TR>
          <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="12" COLOR="#9a6a1f">HRTF-panned, summed into master.</FONT></TD></TR>
        </TABLE>
      >,
      labelloc=t, labeljust=l,
      color="#f0d79a", fillcolor="#fffbf0", style="rounded,filled", penwidth=1.8, margin=18
    ];
    VG  [label=<<B>Voice Gain</B>>];
    PAN [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="0"><TR><TD><B>PannerNode</B></TD></TR><TR><TD CELLPADDING="4"><FONT POINT-SIZE="15">HRTF · inverse distance</FONT></TD></TR></TABLE>>];
    VG -> PAN;
  }

  subgraph cluster_reverb {
    graph [
      label=<
        <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="2">
          <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="16" COLOR="#a5610a"><B>REVERB BUS</B></FONT></TD></TR>
          <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="12" COLOR="#9a6a1f">Procedural convolution impulse.</FONT></TD></TR>
        </TABLE>
      >,
      labelloc=t, labeljust=l,
      color="#f0d79a", fillcolor="#fffbf0", style="rounded,filled", penwidth=1.8, margin=18
    ];
    RIN  [label=<<B>reverb_in</B>>];
    CONV [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="0"><TR><TD><B>ConvolverNode</B></TD></TR><TR><TD CELLPADDING="4"><FONT POINT-SIZE="15">procedural impulse</FONT></TD></TR></TABLE>>];
    RWET [label=<<B>reverb_wet</B>>];
    RIN -> CONV -> RWET;
  }

  subgraph cluster_delay {
    graph [
      label=<
        <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="2">
          <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="16" COLOR="#a5610a"><B>DELAY BUS</B></FONT></TD></TR>
          <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="12" COLOR="#9a6a1f">Low-passed feedback loop.</FONT></TD></TR>
        </TABLE>
      >,
      labelloc=t, labeljust=l,
      color="#f0d79a", fillcolor="#fffbf0", style="rounded,filled", penwidth=1.8, margin=18
    ];
    DIN   [label=<<B>delay_in</B>>];
    DLY   [label=<<B>DelayNode</B>>];
    DTONE [label=<<B>lowpass tone</B>>];
    DWET  [label=<<B>delay_wet</B>>];
    DIN -> DLY -> DTONE -> DWET;
    DTONE -> DLY [label=<<TABLE BORDER="1" CELLBORDER="0" STYLE="ROUNDED" COLOR="#d7dee8" BGCOLOR="#ffffff" CELLSPACING="0" CELLPADDING="4"><TR><TD><FONT POINT-SIZE="13" COLOR="#3d4a5c">feedback</FONT></TD></TR></TABLE>>, color="#a5610a", fontcolor="#a5610a", constraint=false];
  }

  // ---- Master chain ----
  subgraph cluster_master {
    graph [
      label=<
        <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="2">
          <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="16" COLOR="#a5610a"><B>MASTER</B></FONT></TD></TR>
          <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="12" COLOR="#9a6a1f">Sum bus → tone → saturation → compression.</FONT></TD></TR>
        </TABLE>
      >,
      labelloc=t, labeljust=l,
      color="#f0d79a", fillcolor="#fffbf0", style="rounded,filled", penwidth=1.8, margin=18
    ];
    MASTER [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="0"><TR><TD><B>master_gain</B></TD></TR><TR><TD CELLPADDING="4"><FONT POINT-SIZE="15">sum bus</FONT></TD></TR></TABLE>>];
    TONE   [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="0"><TR><TD><B>highpass → lowpass</B></TD></TR><TR><TD CELLPADDING="4"><FONT POINT-SIZE="15">tone shaping</FONT></TD></TR></TABLE>>];
    SAT    [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="0"><TR><TD><B>WaveShaper</B></TD></TR><TR><TD CELLPADDING="4"><FONT POINT-SIZE="15">arctan · wet/dry</FONT></TD></TR></TABLE>>];
    COMP   [label=<<B>Compressor + makeup</B>>];
    MASTER -> TONE -> SAT -> COMP;
  }

  // ---- Terminal + visual tap ----
  DEST [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="0"><TR><TD><B>destination</B></TD></TR><TR><TD CELLPADDING="4"><FONT POINT-SIZE="15">speakers</FONT></TD></TR></TABLE>>, fillcolor="#d8f5de:#effcf2", color="#15803d", penwidth=3.0];
  ANALYSER [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="0"><TR><TD><B>AnalyserNode</B></TD></TR><TR><TD CELLPADDING="4"><FONT POINT-SIZE="15">level → visuals</FONT></TD></TR></TABLE>>, fillcolor="#eaf8ef:#ffffff", color="#22865a"];

  // ---- Signal flow ----
  ENG -> NOTE;
  NOTE -> OSC [lhead=cluster_note];
  ENV -> VG  [lhead=cluster_voice, label=<<TABLE BORDER="1" CELLBORDER="0" STYLE="ROUNDED" COLOR="#d7dee8" BGCOLOR="#ffffff" CELLSPACING="0" CELLPADDING="4"><TR><TD><FONT POINT-SIZE="13" COLOR="#3d4a5c">voice</FONT></TD></TR></TABLE>>];
  ENV -> RIN [lhead=cluster_reverb, label=<<TABLE BORDER="1" CELLBORDER="0" STYLE="ROUNDED" COLOR="#dfe3e9" BGCOLOR="#ffffff" CELLSPACING="0" CELLPADDING="4"><TR><TD><FONT POINT-SIZE="13" COLOR="#6b7280">reverb send</FONT></TD></TR></TABLE>>, style=dashed, color="#6b7280", fontcolor="#6b7280"];
  ENV -> DIN [lhead=cluster_delay, label=<<TABLE BORDER="1" CELLBORDER="0" STYLE="ROUNDED" COLOR="#dfe3e9" BGCOLOR="#ffffff" CELLSPACING="0" CELLPADDING="4"><TR><TD><FONT POINT-SIZE="13" COLOR="#6b7280">delay send</FONT></TD></TR></TABLE>>, style=dashed, color="#6b7280", fontcolor="#6b7280"];
  PAN  -> MASTER [ltail=cluster_voice];
  RWET -> MASTER [ltail=cluster_reverb];
  DWET -> MASTER [ltail=cluster_delay];
  COMP -> DEST [ltail=cluster_master];
  MASTER -> ANALYSER [label=<<TABLE BORDER="1" CELLBORDER="0" STYLE="ROUNDED" COLOR="#d7dee8" BGCOLOR="#ffffff" CELLSPACING="0" CELLPADDING="4"><TR><TD><FONT POINT-SIZE="13" COLOR="#3d4a5c">tap</FONT></TD></TR></TABLE>>, style=dashed, color="#22865a", fontcolor="#22865a", constraint=false];

  // Keep the three parallel buses on one rank under the envelope.
  { rank=same; VG; RIN; DIN; }
}
